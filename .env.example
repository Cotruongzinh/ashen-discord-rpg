DISCORD_TOKEN=your_discord_bot_token
TEST_GUILD_ID=your_test_server_id
FIREBASE_CREDENTIALS=secrets/firebase-service-account.json
FIREBASE_SERVICE_ACCOUNT_JSON=your_firebase_service_account_json_for_hosting

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-5.5
ASHEN_AI_ENABLED=true
OPENAI_MAX_OUTPUT_TOKENS=1200
OPENAI_TIMEOUT_SECONDS=25

# Optional AI auto-generation. Keep disabled until you are comfortable with API cost.
ASHEN_AI_AUTO_GENERATE=false
ASHEN_AI_AUTO_INTERVAL_MINUTES=720
ASHEN_AI_AUTO_THEME=grave bell
ASHEN_AI_AUTO_AREA=forgotten_catacomb
ASHEN_AI_AUTO_LEVEL=5
ASHEN_AI_AUTO_ITEMS=2
ASHEN_AI_AUTO_ENEMIES=2
ASHEN_AI_AUTO_ENCOUNTERS=2
ASHEN_AI_AUTO_APPROVE=false
